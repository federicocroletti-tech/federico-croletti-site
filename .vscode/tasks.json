{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Angular: serve",
			"type": "shell",
			"command": "npm run start",
			"isBackground": true,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Angular: build production",
			"type": "shell",
			"command": "npm run build",
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Angular: test unit",
			"type": "shell",
			"command": "npm test",
			"problemMatcher": [
				"$tsc"
			],
			"group": "test"
		},
		{
			"label": "Angular: verify local",
			"type": "shell",
			"command": "npm run build; npm test",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "test"
		}
	]
}